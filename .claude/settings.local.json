{
  "permissions": {
    "allow": [
      "Skill(codex:setup)",
      "Skill(codex:setup:*)",
      "Bash(node *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(uv run *)",
      "Bash(just *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [{"type": "command", "command": "python3 .claude/tools/hooks/protect_settings.py"}]
      },
      {
        "matcher": "Bash",
        "hooks": [{"type": "command", "command": "python3 .claude/tools/hooks/dangerous_cmd.py"}]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [{"type": "command", "command": "python3 .claude/tools/hooks/autoformat.py"}]
      }
    ]
  }
}
